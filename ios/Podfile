# Uncomment this line to define a global platform for your project
platform :ios, '15.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))

  # Explicitly add TweetNacl to fix CTweetNacl module dependency issue
  pod 'TweetNacl', '~> 1.0'
end

post_install do |installer|
  require 'fileutils'

  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'


      # Fix for CTweetNacl module error with Pusher on Xcode 26.0
      # Disable explicit module builds for Pusher and TweetNacl pods
      if ['PusherSwift', 'PusherSwiftWithEncryption', 'TweetNacl'].include?(target.name)
        config.build_settings['SWIFT_ENABLE_EXPLICIT_MODULES'] = 'NO'
        # Additional settings to resolve module dependencies
        config.build_settings['SWIFT_ENABLE_INCREMENTAL_COMPILATION'] = 'NO'
        config.build_settings['SWIFT_COMPILATION_MODE'] = 'wholemodule'
      end

      # Fix ctweetnacl.h not found
      #
      # On some CocoaPods + Xcode combos, `PusherTweetNacl` compiles the C file
      # from `TweetNacl` (`ctweetnacl.c`) but does not inherit the header search
      # path that points at `ctweetnacl.h` (which lives under
      # `TweetNacl/Sources/CTweetNacl/include`).
      #
      # Ensure both the `TweetNacl` target and the target that compiles it
      # (commonly `PusherTweetNacl`) can see that include folder.
      if ['TweetNacl', 'PusherTweetNacl'].include?(target.name)
        config.build_settings['HEADER_SEARCH_PATHS'] ||= '$(inherited)'
        config.build_settings['USER_HEADER_SEARCH_PATHS'] ||= '$(inherited)'

        tweetnacl_include = '"$(PODS_ROOT)/TweetNacl/Sources/CTweetNacl/include"'
        config.build_settings['HEADER_SEARCH_PATHS'] = "#{config.build_settings['HEADER_SEARCH_PATHS']} #{tweetnacl_include}"
        config.build_settings['USER_HEADER_SEARCH_PATHS'] = "#{config.build_settings['USER_HEADER_SEARCH_PATHS']} #{tweetnacl_include}"
      end


    end
  end
  # Additional project-level settings for all targets
  installer.pods_project.build_configurations.each do |config|
    config.build_settings['SWIFT_ENABLE_EXPLICIT_MODULES'] = 'NO'
  end

  # Last-resort guard: some builds still fail to locate `ctweetnacl.h` when
  # compiling `ctweetnacl.c` (from the `TweetNacl` pod). The source includes
  # `"ctweetnacl.h"` from its own folder, but the header is nested under
  # `CTweetNacl/include/`. Create a local copy next to the C file.
  tweetnacl_header = File.join(installer.sandbox.root.to_s, 'TweetNacl', 'Sources', 'CTweetNacl', 'include', 'ctweetnacl.h')
  tweetnacl_header_dest = File.join(installer.sandbox.root.to_s, 'TweetNacl', 'Sources', 'CTweetNacl', 'ctweetnacl.h')
  if File.exist?(tweetnacl_header) && !File.exist?(tweetnacl_header_dest)
    FileUtils.cp(tweetnacl_header, tweetnacl_header_dest)
  end
end
